{
  "name": "tree-sitter-chiba",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for the Chiba programming language",
  "main": "bindings/node",
  "keywords": ["tree-sitter", "parser", "chiba"],
  "license": "MIT",
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.26.0"
  },
  "scripts": {
    "build": "tree-sitter generate && tree-sitter build --wasm",
    "test": "tree-sitter test",
    "generate": "tree-sitter generate"
  },
  "tree-sitter": [
    {
      "scope": "source.chiba",
      "file-types": ["chiba"],
      "highlights": "queries/highlights.scm",
      "injection-regex": "chiba"
    }
  ]
}
