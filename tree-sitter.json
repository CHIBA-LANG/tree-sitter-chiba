      "highlights": "queries/highlights.scm",
      "injection-regex": "^chiba$"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "description": "Tree-sitter grammar for the Chiba programming language",
    "repository": "https://github.com/chiba-lang/tree-sitter-chiba",
    "links": {
      "repository": "https://github.com/chiba-lang/tree-sitter-chiba"
    }
  }
}
